#!/usr/bin/env node

const fs = require("fs");
const path = require("path");

const binDir = path.dirname(fs.realpathSync(__filename));
const { runLogCommand } = require(path.join(binDir, "..", "lib", "codex-loop", "log-command"));

runLogCommand({
  commandName: "codex-plan-log",
  loopName: "codex-plan-loop",
  examples: [
    "codex-plan-log",
    "codex-plan-log list",
    "codex-plan-log show latest --json",
    "codex-plan-log transcript latest cycle-1-progress",
    "codex-plan-log events latest cycle-1-progress",
  ],
  printFinalSummary(summary) {
    console.log(`Status: ${summary.status || "unknown"}`);
    if (summary.summary) {
      console.log(`Summary: ${summary.summary}`);
    }
    const bucket2 = summary.bucket2Items || [];
    console.log(`Bucket II: ${bucket2.length}`);
  },
});

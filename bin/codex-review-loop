#!/usr/bin/env node

const fs = require("fs");
const path = require("path");
const { spawn, spawnSync } = require("child_process");

const DEFAULT_MAX_ITERATIONS = 5;
const DEFAULT_SANDBOX = "workspace-write";
const DEFAULT_LOG_STYLE = "live";
const DEFAULT_SCOPE = "uncommitted changes";

function usage() {
  console.log(`Usage: codex-review-loop [options]

Options:
  --scope <text>          Review target. Default: ${DEFAULT_SCOPE}
  --max-iterations <n>    Maximum review/fix iterations. Default: ${DEFAULT_MAX_ITERATIONS}
  --sandbox <mode>        Codex sandbox mode. Default: ${DEFAULT_SANDBOX}
  --model <model>         Optional model override passed to codex exec.
  --network               Enable network access inside workspace-write sandbox.
  --review-only           Review and report without editing files.
  --log-style <style>     Terminal logging: live, quiet, or jsonl. Default: ${DEFAULT_LOG_STYLE}
  --help                  Show this help.

The wrapper runs fresh Codex review and fix phases, writes private run logs
under .git/codex-review-loop/, applies only safe Bucket I fixes by default,
and never stages, commits, or pushes.`);
}

function parseArgs(argv) {
  const options = {
    scope: DEFAULT_SCOPE,
    maxIterations: DEFAULT_MAX_ITERATIONS,
    sandbox: DEFAULT_SANDBOX,
    model: "",
    network: false,
    reviewOnly: false,
    logStyle: DEFAULT_LOG_STYLE,
  };

  for (let i = 0; i < argv.length; i += 1) {
    const arg = argv[i];
    if (arg === "--help" || arg === "-h") {
      usage();
      process.exit(0);
    }

    if (arg === "--network") {
      options.network = true;
      continue;
    }

    if (arg === "--review-only") {
      options.reviewOnly = true;
      continue;
    }

    if (
      arg === "--scope" ||
      arg === "--max-iterations" ||
      arg === "--sandbox" ||
      arg === "--model" ||
      arg === "--log-style"
    ) {
      const value = argv[i + 1];
      if (!value || value.startsWith("--")) {
        throw new Error(`${arg} requires a value`);
      }
      i += 1;

      if (arg === "--scope") {
        options.scope = value;
      } else if (arg === "--max-iterations") {
        options.maxIterations = parsePositiveInteger(value, "max-iterations");
      } else if (arg === "--sandbox") {
        options.sandbox = value;
      } else if (arg === "--model") {
        options.model = value;
      } else {
        options.logStyle = value;
      }
      continue;
    }

    if (arg.startsWith("--")) {
      throw new Error(`unknown option: ${arg}`);
    }

    throw new Error(`unexpected positional argument: ${arg}`);
  }

  if (!options.scope.trim()) {
    throw new Error("scope must not be empty");
  }
  if (!["read-only", "workspace-write", "danger-full-access"].includes(options.sandbox)) {
    throw new Error(`unsupported sandbox mode: ${options.sandbox}`);
  }
  if (!["live", "quiet", "jsonl"].includes(options.logStyle)) {
    throw new Error(`unsupported log style: ${options.logStyle}`);
  }
  if (options.reviewOnly && options.sandbox !== "read-only") {
    options.sandbox = "read-only";
  }

  return options;
}

function parsePositiveInteger(value, label) {
  const number = Number(value);
  if (!Number.isInteger(number) || number < 1) {
    throw new Error(`${label} must be a positive integer`);
  }
  return number;
}

function runSync(command, args, options = {}) {
  const result = spawnSync(command, args, {
    cwd: options.cwd,
    encoding: "utf8",
    maxBuffer: 50 * 1024 * 1024,
  });

  if (result.error) {
    throw result.error;
  }

  return result;
}

function requireSuccessful(command, args, options = {}) {
  const result = runSync(command, args, options);
  if (result.status !== 0) {
    const stderr = result.stderr ? result.stderr.trim() : "";
    const stdout = result.stdout ? result.stdout.trim() : "";
    throw new Error(`${command} ${args.join(" ")} failed${stderr || stdout ? `: ${stderr || stdout}` : ""}`);
  }
  return result.stdout.trim();
}

function findRepoRoot() {
  return requireSuccessful("git", ["rev-parse", "--show-toplevel"]);
}

function ensureCommand(name) {
  const result = runSync("sh", ["-c", `command -v ${shellQuote(name)}`]);
  if (result.status !== 0) {
    throw new Error(`required command not found on PATH: ${name}`);
  }
}

function shellQuote(value) {
  return `'${String(value).replace(/'/g, "'\\''")}'`;
}

function makeRunDir(repoRoot) {
  const gitDir = requireSuccessful("git", ["rev-parse", "--git-dir"], { cwd: repoRoot });
  const absoluteGitDir = path.isAbsolute(gitDir) ? gitDir : path.join(repoRoot, gitDir);
  const timestamp = new Date().toISOString().replace(/[:.]/g, "-");
  const runDir = path.join(absoluteGitDir, "codex-review-loop", timestamp);
  fs.mkdirSync(runDir, { recursive: true });
  return runDir;
}

function writeJson(file, value) {
  fs.writeFileSync(file, `${JSON.stringify(value, null, 2)}\n`);
}

function reviewSchema() {
  return {
    type: "object",
    additionalProperties: false,
    properties: {
      status: {
        type: "string",
        enum: ["clean", "bucket1_candidates", "bucket2_only", "blocked", "validation_failed"],
      },
      summary: { type: "string" },
      bucket1_candidates: {
        type: "array",
        items: {
          type: "object",
          additionalProperties: false,
          properties: {
            priority: { type: "string" },
            title: { type: "string" },
            design_signal: { type: "string" },
            evidence: { type: "string" },
            scenario: { type: "string" },
            impact: { type: "string" },
            fix: { type: "string" },
          },
          required: ["priority", "title", "design_signal", "evidence", "scenario", "impact", "fix"],
        },
      },
      bucket2_items: {
        type: "array",
        items: {
          type: "object",
          additionalProperties: false,
          properties: {
            priority: { type: "string" },
            title: { type: "string" },
            design_signal: { type: "string" },
            recommendation: { type: "string" },
            tradeoffs: { type: "string" },
            blocks_completion: { type: "boolean" },
          },
          required: ["priority", "title", "design_signal", "recommendation", "tradeoffs", "blocks_completion"],
        },
      },
      keep_as_is: {
        type: "array",
        items: {
          type: "object",
          additionalProperties: false,
          properties: {
            title: { type: "string" },
            reason: { type: "string" },
          },
          required: ["title", "reason"],
        },
      },
      validation: { type: "string" },
    },
    required: ["status", "summary", "bucket1_candidates", "bucket2_items", "keep_as_is", "validation"],
  };
}

function fixSchema() {
  return {
    type: "object",
    additionalProperties: false,
    properties: {
      status: {
        type: "string",
        enum: ["applied", "nothing_applied", "blocked", "validation_failed", "failed"],
      },
      summary: { type: "string" },
      applied_count: { type: "integer", minimum: 0 },
      changed_files: {
        type: "array",
        items: { type: "string" },
      },
      validation: { type: "string" },
    },
    required: ["status", "summary", "applied_count", "changed_files", "validation"],
  };
}

function buildCodexArgs({ options, schemaFile, lastMessageFile, prompt }) {
  const args = [
    "exec",
    "--json",
    "-o",
    lastMessageFile,
    "--output-schema",
    schemaFile,
    "--sandbox",
    options.sandbox,
    "-c",
    'approval_policy="never"',
  ];

  if (options.network) {
    args.push("-c", "sandbox_workspace_write.network_access=true");
  }

  if (options.model) {
    args.push("--model", options.model);
  }

  args.push(prompt);
  return args;
}

function runCodexPhase({ repoRoot, runDir, phaseName, iteration, options, schema, prompt }) {
  const prefix = `iteration-${iteration}-${phaseName}`;
  const schemaFile = path.join(runDir, `${prefix}-schema.json`);
  const lastMessageFile = path.join(runDir, `${prefix}-last-message.json`);
  const jsonlFile = path.join(runDir, `${prefix}.jsonl`);
  const stderrFile = path.join(runDir, `${prefix}.stderr.log`);
  const transcriptFile = path.join(runDir, `${prefix}.transcript.log`);

  writeJson(schemaFile, schema);

  const args = buildCodexArgs({ options, schemaFile, lastMessageFile, prompt });
  console.error(`[codex-review-loop] starting ${prefix}`);

  return new Promise((resolve, reject) => {
    const stdout = fs.createWriteStream(jsonlFile);
    const stderr = fs.createWriteStream(stderrFile);
    const transcript = fs.createWriteStream(transcriptFile);
    const renderer = createPhaseRenderer({
      prefix,
      style: options.logStyle,
      transcript,
    });
    const child = spawn("codex", args, {
      cwd: repoRoot,
      stdio: ["ignore", "pipe", "pipe"],
    });

    child.stdout.on("data", (chunk) => {
      stdout.write(chunk);
      renderer.write(chunk);
    });

    child.stderr.on("data", (chunk) => {
      stderr.write(chunk);
    });

    child.on("error", reject);
    child.on("close", (code) => {
      renderer.end();
      Promise.all([finishStream(stdout), finishStream(stderr), finishStream(transcript)])
        .then(() => {
          if (code !== 0) {
            reject(new Error(`${prefix} failed with exit code ${code}; see ${stderrFile} and ${transcriptFile}`));
            return;
          }

          try {
            const raw = readFinalMessage(lastMessageFile, jsonlFile);
            const parsed = parseStructuredMessage(raw);
            writeJson(path.join(runDir, `${prefix}-parsed.json`), parsed);
            resolve(parsed);
          } catch (error) {
            reject(new Error(`${prefix} did not produce parseable structured output: ${error.message}`));
          }
        })
        .catch(reject);
    });
  });
}

function finishStream(stream) {
  return new Promise((resolve, reject) => {
    stream.on("error", reject);
    stream.end(resolve);
  });
}

function createPhaseRenderer({ prefix, style, transcript }) {
  let buffer = "";

  function emit(message) {
    const line = `[${prefix}] ${message}\n`;
    transcript.write(line);
    if (style === "live") {
      process.stderr.write(line);
    }
  }

  emit("phase started");

  return {
    write(chunk) {
      const text = chunk.toString("utf8");
      if (style === "jsonl") {
        process.stderr.write(text);
      }

      buffer += text;
      const lines = buffer.split(/\r?\n/);
      buffer = lines.pop() || "";

      for (const line of lines) {
        renderJsonLine(line, emit);
      }
    },
    end() {
      if (buffer.trim()) {
        renderJsonLine(buffer, emit);
      }
      emit("phase finished");
    },
  };
}

function renderJsonLine(line, emit) {
  if (!line.trim()) return;

  let event;
  try {
    event = JSON.parse(line);
  } catch {
    emit(`unparsed event: ${truncate(line.trim(), 500)}`);
    return;
  }

  if (event.type === "thread.started") {
    emit(`thread started: ${event.thread_id || "unknown"}`);
    return;
  }

  if (event.type === "turn.started") {
    emit("turn started");
    return;
  }

  if (event.type === "turn.completed") {
    const usage = event.usage ? ` ${JSON.stringify(event.usage)}` : "";
    emit(`turn completed${usage}`);
    return;
  }

  if (event.type === "turn.failed" || event.type === "error") {
    emit(`${event.type}: ${event.message || event.error || "unknown error"}`);
    return;
  }

  const item = event.item || {};
  if (!item.type) {
    emit(`${event.type || "event"}: ${truncate(JSON.stringify(event), 1000)}`);
    return;
  }

  if (event.type === "item.started" && item.type === "command_execution") {
    emit(`running: ${compactCommand(item.command || "")}`);
    return;
  }

  if (event.type === "item.completed" && item.type === "command_execution") {
    const exitText = item.exit_code === null || item.exit_code === undefined ? "" : ` exit ${item.exit_code}`;
    emit(`command ${item.status || "completed"}${exitText}: ${compactCommand(item.command || "")}`);
    if (item.aggregated_output && item.aggregated_output.trim()) {
      emitBlock("output", item.aggregated_output, emit, 1200);
    }
    return;
  }

  if (item.type === "agent_message") {
    emitBlock("agent", formatAgentMessage(item.text || ""), emit, 4000);
    return;
  }

  emit(`${item.type}: ${truncate(JSON.stringify(item), 1000)}`);
}

function compactCommand(command) {
  return String(command || "")
    .replace(/\s+/g, " ")
    .trim();
}

function formatAgentMessage(text) {
  const trimmed = String(text || "").trim();
  if (!trimmed.startsWith("{")) return trimmed;

  try {
    const value = JSON.parse(trimmed);
    if (!value || typeof value !== "object" || Array.isArray(value)) {
      return trimmed;
    }

    const lines = [];
    if (value.status || value.summary) {
      lines.push([value.status, value.summary].filter(Boolean).join(" - "));
    }
    if (Array.isArray(value.bucket1_candidates)) {
      lines.push(`Bucket I candidates: ${value.bucket1_candidates.length}`);
    }
    if (Array.isArray(value.bucket2_items)) {
      lines.push(`Bucket II: ${value.bucket2_items.length}`);
    }
    if (typeof value.applied_count === "number") {
      lines.push(`Applied: ${value.applied_count}`);
    }
    if (value.validation) {
      lines.push(`Validation: ${value.validation}`);
    }
    return lines.length ? lines.join("\n") : trimmed;
  } catch {
    return trimmed;
  }
}

function emitBlock(label, text, emit, maxLength) {
  const rendered = truncate(String(text || "").trim(), maxLength);
  if (!rendered) return;
  const lines = rendered.split(/\r?\n/);
  emit(`${label}: ${lines[0]}`);
  for (const line of lines.slice(1)) {
    emit(`  ${line}`);
  }
}

function truncate(text, maxLength) {
  if (text.length <= maxLength) return text;
  return `${text.slice(0, maxLength).trimEnd()}... [truncated ${text.length - maxLength} chars]`;
}

function readFinalMessage(lastMessageFile, jsonlFile) {
  if (fs.existsSync(lastMessageFile)) {
    const raw = fs.readFileSync(lastMessageFile, "utf8").trim();
    if (raw) return raw;
  }

  if (!fs.existsSync(jsonlFile)) {
    throw new Error("missing final message and JSONL log");
  }

  const lines = fs.readFileSync(jsonlFile, "utf8").split(/\r?\n/);
  let lastAgentMessage = "";
  for (const line of lines) {
    if (!line.trim()) continue;
    try {
      const event = JSON.parse(line);
      const item = event.item;
      if (item && item.type === "agent_message" && typeof item.text === "string") {
        lastAgentMessage = item.text;
      }
    } catch {
      // Ignore malformed log lines; the final message file is authoritative.
    }
  }

  if (!lastAgentMessage) {
    throw new Error("no agent message found");
  }
  return lastAgentMessage.trim();
}

function parseStructuredMessage(raw) {
  try {
    return JSON.parse(raw);
  } catch {
    const fenced = raw.match(/```(?:json)?\s*([\s\S]*?)```/i);
    if (fenced) {
      return JSON.parse(fenced[1].trim());
    }
    throw new Error("final message was not valid JSON");
  }
}

function buildReviewPrompt({ scope, iteration, reviewOnly }) {
  return `Run a strict post-implementation code review for this target:
${scope}

Iteration: ${iteration}
Mode: ${reviewOnly ? "review-only; do not edit files" : "review phase only; do not edit files"}

Requirements:
- Inspect the real repo state before deciding. For uncommitted changes, inspect git status, git diff, git diff --staged, and relevant untracked files.
- Distinguish issues introduced by the reviewed change from pre-existing debt.
- Prefer no finding over a weak finding.
- Do not create, read, or update a persistent review ledger.
- Do not stage, commit, push, or modify files in this phase.
- Bucket I means a concrete safe in-scope fix that can be applied without product, architecture, rollout, compatibility, or risk judgment.
- Bucket II means a real improvement that needs user judgment before implementation.
- Keep As-Is is for meaningful concerns rejected after inspection.
- Record only findings that pass this gate: discrete, actionable, material, concrete affected path, explicit trigger scenario, narrow evidence, likely author would fix it.
- Use priorities P0, P1, P2, or P3.
- Use exactly one design signal: simple local mistake; weak validation or invariant gap; unclear ownership / boundary problem; weak type or schema model; state, lifecycle, concurrency, or ordering hazard; over-abstraction, under-abstraction, or duplicated logic; brittle integration or contract mismatch.
- Set status to bucket1_candidates if any safe Bucket I candidate exists.
- Set status to bucket2_only if no Bucket I candidate exists and unresolved Bucket II exists.
- Set status to blocked when scope/context is insufficient or a blocking decision is needed.
- Set status to validation_failed when an existing validation failure prevents reliable review.
- Set status to clean when no meaningful issue remains.

Return only JSON matching the provided schema.`;
}

function buildFixPrompt({ scope, iteration, candidates }) {
  return `Apply only the accepted safe Bucket I fixes for this review target:
${scope}

Iteration: ${iteration}
Bucket I candidates:
${JSON.stringify(candidates, null, 2)}

Requirements:
- Re-verify every candidate against the real code before editing.
- Apply only concrete, safe, in-scope fixes that are root-cause-fixable now.
- Reject or skip anything requiring product, domain, architecture, rollout, compatibility, churn, or risk judgment.
- Keep edits tightly scoped to the reviewed change.
- Do not create, read, or update a persistent review ledger.
- Do not stage, commit, push, or implement Bucket II items.
- Run focused validation when practical.
- Set status to applied only when at least one fix was applied.
- Set status to nothing_applied when all candidates were rejected or already resolved.
- Set status to blocked when user input or external context is required.
- Set status to validation_failed when validation fails due to the applied fix or blocks safe continuation.
- Set status to failed for execution failure that should stop automation.

Return only JSON matching the provided schema.`;
}

function summarizeBucket2(items) {
  if (!items.length) return "No unresolved Bucket II decisions.";
  return items
    .map((item, index) => {
      const blocking = item.blocks_completion ? "blocking" : "decision";
      return `${index + 1}. [${blocking}] ${item.priority} ${item.title}: ${item.recommendation}`;
    })
    .join("\n");
}

function uniqueBucket2(existing, incoming) {
  const seen = new Set(existing.map((item) => `${item.priority}\0${item.title}\0${item.recommendation}`));
  const merged = [...existing];
  for (const item of incoming) {
    const key = `${item.priority}\0${item.title}\0${item.recommendation}`;
    if (!seen.has(key)) {
      seen.add(key);
      merged.push(item);
    }
  }
  return merged;
}

function gitStatus(repoRoot) {
  return requireSuccessful("git", ["status", "--porcelain=v1"], { cwd: repoRoot });
}

async function main() {
  const options = parseArgs(process.argv.slice(2));
  const repoRoot = findRepoRoot();

  ensureCommand("codex");

  const runDir = makeRunDir(repoRoot);
  let bucket2Items = [];
  let appliedCount = 0;
  let lastReview = null;
  let lastFix = null;

  console.error(`[codex-review-loop] repo: ${repoRoot}`);
  console.error(`[codex-review-loop] scope: ${options.scope}`);
  console.error(`[codex-review-loop] run state: ${runDir}`);
  writeJson(path.join(runDir, "start.json"), {
    repoRoot,
    scope: options.scope,
    options,
    status: gitStatus(repoRoot),
  });

  for (let iteration = 1; iteration <= options.maxIterations; iteration += 1) {
    lastReview = await runCodexPhase({
      repoRoot,
      runDir,
      phaseName: "review",
      iteration,
      options,
      schema: reviewSchema(),
      prompt: buildReviewPrompt({
        scope: options.scope,
        iteration,
        reviewOnly: options.reviewOnly,
      }),
    });

    bucket2Items = uniqueBucket2(bucket2Items, lastReview.bucket2_items || []);
    writeJson(path.join(runDir, `iteration-${iteration}-bucket2.json`), bucket2Items);

    if (lastReview.status === "blocked") {
      return finish("blocked", runDir, options.scope, appliedCount, bucket2Items, lastReview.summary, lastReview.validation);
    }
    if (lastReview.status === "validation_failed") {
      return finish("validation_failed", runDir, options.scope, appliedCount, bucket2Items, lastReview.summary, lastReview.validation);
    }

    const candidates = lastReview.bucket1_candidates || [];
    if (options.reviewOnly) {
      const status = candidates.length ? "review_only_findings" : bucket2Items.length ? "decision_needed" : "clean";
      return finish(status, runDir, options.scope, appliedCount, bucket2Items, lastReview.summary, lastReview.validation);
    }

    if (!candidates.length) {
      const status = bucket2Items.length ? "decision_needed" : "clean";
      return finish(status, runDir, options.scope, appliedCount, bucket2Items, lastReview.summary, lastReview.validation);
    }

    lastFix = await runCodexPhase({
      repoRoot,
      runDir,
      phaseName: "fix",
      iteration,
      options,
      schema: fixSchema(),
      prompt: buildFixPrompt({
        scope: options.scope,
        iteration,
        candidates,
      }),
    });

    appliedCount += lastFix.applied_count || 0;

    if (lastFix.status === "blocked") {
      return finish("blocked", runDir, options.scope, appliedCount, bucket2Items, lastFix.summary, lastFix.validation);
    }
    if (lastFix.status === "validation_failed") {
      return finish("validation_failed", runDir, options.scope, appliedCount, bucket2Items, lastFix.summary, lastFix.validation);
    }
    if (lastFix.status === "failed") {
      return finish("failed", runDir, options.scope, appliedCount, bucket2Items, lastFix.summary, lastFix.validation);
    }
    if (lastFix.status === "nothing_applied" || !lastFix.applied_count) {
      const status = bucket2Items.length ? "decision_needed" : "clean";
      return finish(status, runDir, options.scope, appliedCount, bucket2Items, lastFix.summary, lastFix.validation);
    }
  }

  const summary = lastFix
    ? lastFix.summary
    : lastReview
      ? lastReview.summary
      : `Reached max iteration limit (${options.maxIterations}).`;
  const validation = lastFix ? lastFix.validation : lastReview ? lastReview.validation : "";
  return finish("max_iterations_reached", runDir, options.scope, appliedCount, bucket2Items, summary, validation);
}

function finish(status, runDir, scope, appliedCount, bucket2Items, summary, validation) {
  const result = {
    status,
    scope,
    summary,
    runDir,
    appliedCount,
    bucket2Items,
    validation: validation || "",
  };
  writeJson(path.join(runDir, "final-summary.json"), result);

  console.log(`Status: ${status}`);
  if (summary) console.log(`Summary: ${summary}`);
  console.log(`Scope: ${scope}`);
  console.log(`Applied Bucket I fixes: ${appliedCount}`);
  if (validation) console.log(`Validation: ${validation}`);
  console.log(`Run state: ${runDir}`);
  console.log("");
  console.log("Bucket II:");
  console.log(summarizeBucket2(bucket2Items));

  if (["clean", "review_only_findings"].includes(status)) {
    return 0;
  }
  return 1;
}

main()
  .then((exitCode) => {
    process.exitCode = exitCode;
  })
  .catch((error) => {
    console.error(`[codex-review-loop] error: ${error.message}`);
    process.exitCode = 1;
  });

#!/usr/bin/env node

const fs = require("fs");
const path = require("path");

const binDir = path.dirname(fs.realpathSync(__filename));
const { runLogCommand } = require(path.join(binDir, "..", "lib", "codex-loop", "log-command"));

runLogCommand({
  commandName: "codex-review-log",
  loopName: "codex-review-loop",
  includeStart: true,
  examples: [
    "codex-review-log",
    "codex-review-log list",
    "codex-review-log show latest --json",
    "codex-review-log transcript latest iteration-1-review",
    "codex-review-log events latest iteration-1-fix",
  ],
  printFinalSummary(summary) {
    console.log(`Status: ${summary.status || "unknown"}`);
    if (summary.scope) {
      console.log(`Scope: ${summary.scope}`);
    }
    if (summary.summary) {
      console.log(`Summary: ${summary.summary}`);
    }
    console.log(`Applied Bucket I fixes: ${summary.appliedCount || 0}`);
    const bucket2 = summary.bucket2Items || [];
    console.log(`Bucket II: ${bucket2.length}`);
  },
});

#!/usr/bin/env node

const fs = require("fs");
const path = require("path");
const { spawnSync } = require("child_process");

const binDir = path.dirname(fs.realpathSync(__filename));
const { runCodexPhase: runSharedCodexPhase } = require(path.join(binDir, "..", "lib", "codex-loop", "codex-phase"));
const { buildPlanReviewPrompt } = require(path.join(binDir, "..", "lib", "codex-loop", "review-prompts"));

const DEFAULT_MAX_CYCLES = 20;
const DEFAULT_SANDBOX = "workspace-write";
const DEFAULT_REVIEW_LIMIT = 5;
const DEFAULT_LOG_STYLE = "live";

function usage() {
  console.log(`Usage: codex-plan-loop <plan-file> [options]

Options:
  --max-cycles <n>       Maximum progress cycles to run. Default: ${DEFAULT_MAX_CYCLES}
  --sandbox <mode>       Codex sandbox mode. Default: ${DEFAULT_SANDBOX}
  --model <model>        Optional model override passed to codex exec.
  --reasoning-effort <n> Optional reasoning effort override passed to codex exec.
  --service-tier <tier>  Optional service tier override passed to codex exec.
  --fast                 Shortcut for --service-tier fast.
  --network              Force network access inside workspace-write sandbox.
  --no-network           Force network access off inside workspace-write sandbox.
  --review-limit <n>     Maximum review passes per progress cycle. Default: ${DEFAULT_REVIEW_LIMIT}
  --log-style <style>    Terminal logging: live, quiet, or jsonl. Default: ${DEFAULT_LOG_STYLE}
  --print-effective-config
                         Print resolved model/reasoning/fast-mode settings and exit.
  --help                 Show this help.

The wrapper requires a clean git worktree before starting. It writes private
run logs under .git/codex-plan-loop/ and auto-commits each accepted slice.
Raw JSONL, stderr, and readable transcript logs are saved for each Codex phase.`);
}

function parseArgs(argv) {
  const options = {
    maxCycles: DEFAULT_MAX_CYCLES,
    sandbox: DEFAULT_SANDBOX,
    model: "",
    reasoningEffort: "",
    serviceTier: "",
    network: null,
    reviewLimit: DEFAULT_REVIEW_LIMIT,
    logStyle: DEFAULT_LOG_STYLE,
    printEffectiveConfig: false,
  };
  let planFile = "";

  for (let i = 0; i < argv.length; i += 1) {
    const arg = argv[i];
    if (arg === "--help" || arg === "-h") {
      usage();
      process.exit(0);
    }

    if (arg === "--network") {
      options.network = true;
      continue;
    }

    if (arg === "--no-network") {
      options.network = false;
      continue;
    }

    if (arg === "--fast") {
      options.serviceTier = "fast";
      continue;
    }

    if (arg === "--print-effective-config") {
      options.printEffectiveConfig = true;
      continue;
    }

    if (
      arg === "--max-cycles" ||
      arg === "--sandbox" ||
      arg === "--model" ||
      arg === "--reasoning-effort" ||
      arg === "--service-tier" ||
      arg === "--review-limit" ||
      arg === "--log-style"
    ) {
      const value = argv[i + 1];
      if (!value || value.startsWith("--")) {
        throw new Error(`${arg} requires a value`);
      }
      i += 1;

      if (arg === "--max-cycles") {
        options.maxCycles = parsePositiveInteger(value, "max-cycles");
      } else if (arg === "--sandbox") {
        options.sandbox = value;
      } else if (arg === "--model") {
        options.model = value;
      } else if (arg === "--reasoning-effort") {
        options.reasoningEffort = value;
      } else if (arg === "--service-tier") {
        options.serviceTier = value;
      } else if (arg === "--review-limit") {
        options.reviewLimit = parsePositiveInteger(value, "review-limit");
      } else {
        options.logStyle = value;
      }
      continue;
    }

    if (arg.startsWith("--")) {
      throw new Error(`unknown option: ${arg}`);
    }

    if (planFile) {
      throw new Error(`unexpected positional argument: ${arg}`);
    }
    planFile = arg;
  }

  if (!planFile) {
    throw new Error("missing required <plan-file>");
  }

  if (!["read-only", "workspace-write", "danger-full-access"].includes(options.sandbox)) {
    throw new Error(`unsupported sandbox mode: ${options.sandbox}`);
  }
  if (!["live", "quiet", "jsonl"].includes(options.logStyle)) {
    throw new Error(`unsupported log style: ${options.logStyle}`);
  }
  if (options.reasoningEffort && !["low", "medium", "high", "xhigh"].includes(options.reasoningEffort)) {
    throw new Error(`unsupported reasoning effort: ${options.reasoningEffort}`);
  }
  if (options.serviceTier && !/^[A-Za-z0-9._-]+$/.test(options.serviceTier)) {
    throw new Error(`unsupported service tier: ${options.serviceTier}`);
  }

  return { planFile, options };
}

function parsePositiveInteger(value, label) {
  const number = Number(value);
  if (!Number.isInteger(number) || number < 1) {
    throw new Error(`${label} must be a positive integer`);
  }
  return number;
}

function runSync(command, args, options = {}) {
  const result = spawnSync(command, args, {
    cwd: options.cwd,
    encoding: "utf8",
    maxBuffer: 50 * 1024 * 1024,
  });

  if (result.error) {
    throw result.error;
  }

  return result;
}

function requireSuccessful(command, args, options = {}) {
  const result = runSync(command, args, options);
  if (result.status !== 0) {
    const stderr = result.stderr ? result.stderr.trim() : "";
    const stdout = result.stdout ? result.stdout.trim() : "";
    throw new Error(`${command} ${args.join(" ")} failed${stderr || stdout ? `: ${stderr || stdout}` : ""}`);
  }
  return result.stdout.trim();
}

function findRepoRoot() {
  return requireSuccessful("git", ["rev-parse", "--show-toplevel"]);
}

function ensureCleanWorktree(repoRoot) {
  const status = requireSuccessful("git", ["status", "--porcelain=v1"], { cwd: repoRoot });
  if (status) {
    throw new Error(`worktree must be clean before starting:\n${status}`);
  }
}

function ensureCommand(name) {
  const result = runSync("sh", ["-c", `command -v ${shellQuote(name)}`]);
  if (result.status !== 0) {
    throw new Error(`required command not found on PATH: ${name}`);
  }
}

function shellQuote(value) {
  return `'${String(value).replace(/'/g, "'\\''")}'`;
}

function makeRunDir(repoRoot) {
  const gitDir = requireSuccessful("git", ["rev-parse", "--git-dir"], { cwd: repoRoot });
  const absoluteGitDir = path.isAbsolute(gitDir) ? gitDir : path.join(repoRoot, gitDir);
  const timestamp = new Date().toISOString().replace(/[:.]/g, "-");
  const runDir = path.join(absoluteGitDir, "codex-plan-loop", timestamp);
  fs.mkdirSync(runDir, { recursive: true });
  return runDir;
}

function writeJson(file, value) {
  fs.writeFileSync(file, `${JSON.stringify(value, null, 2)}\n`);
}

function codexHome() {
  return process.env.CODEX_HOME || path.join(homeDir(), ".codex");
}

function homeDir() {
  return process.env.HOME || process.env.USERPROFILE || "";
}

function readCodexConfig() {
  const configFile = path.join(codexHome(), "config.toml");
  if (!fs.existsSync(configFile)) {
    return { path: configFile, values: {}, tables: {} };
  }

  const values = {};
  const tables = {};
  const lines = fs.readFileSync(configFile, "utf8").split(/\r?\n/);
  let tableName = "";
  for (const rawLine of lines) {
    const line = stripTomlComment(rawLine).trim();
    if (!line) continue;
    if (line.startsWith("[") && line.endsWith("]")) {
      tableName = line.replace(/^\[+|\]+$/g, "");
      if (!tables[tableName]) tables[tableName] = {};
      continue;
    }

    const match = line.match(/^([A-Za-z0-9_-]+)\s*=\s*(.+)$/);
    if (!match) continue;
    const parsed = parseTomlScalar(match[2].trim());
    if (!tableName) {
      values[match[1]] = parsed;
    } else {
      tables[tableName][match[1]] = parsed;
    }
  }

  return { path: configFile, values, tables };
}

function stripTomlComment(line) {
  let inString = false;
  let quote = "";
  for (let i = 0; i < line.length; i += 1) {
    const char = line[i];
    if ((char === '"' || char === "'") && line[i - 1] !== "\\") {
      if (!inString) {
        inString = true;
        quote = char;
      } else if (quote === char) {
        inString = false;
        quote = "";
      }
    }
    if (char === "#" && !inString) {
      return line.slice(0, i);
    }
  }
  return line;
}

function parseTomlScalar(value) {
  const quoted = value.match(/^"([\s\S]*)"$/) || value.match(/^'([\s\S]*)'$/);
  if (quoted) return quoted[1];
  if (value === "true") return true;
  if (value === "false") return false;
  return value;
}

function effectiveCodexConfig(options) {
  const config = readCodexConfig();
  const modelFromConfig = stringValue(config.values.model);
  const reasoningFromConfig = stringValue(config.values.model_reasoning_effort);
  const serviceTierFromConfig = stringValue(config.values.service_tier);
  const fastModeFeatureFromConfig = booleanValue(config.tables.features && config.tables.features.fast_mode);
  const networkFromConfig = booleanValue(
    config.tables.sandbox_workspace_write && config.tables.sandbox_workspace_write.network_access,
  );
  const serviceTier = options.serviceTier || serviceTierFromConfig || "Codex default";
  const serviceTierSource = options.serviceTier ? "flag" : serviceTierFromConfig ? "config" : "codex-default";
  const network = typeof options.network === "boolean" ? options.network : networkFromConfig;
  const networkSource = typeof options.network === "boolean" ? "flag" : networkFromConfig !== null ? "config" : "codex-default";
  const fastModeFeatureEnabled = fastModeFeatureFromConfig !== false;
  const fastModeApplied = serviceTier === "fast" && fastModeFeatureEnabled;
  const fastModeDetail =
    serviceTier === "fast" && !fastModeFeatureEnabled
      ? "service_tier=fast but features.fast_mode=false"
      : `service_tier=${serviceTier}`;
  return {
    model: options.model || modelFromConfig || "Codex default",
    modelSource: options.model ? "flag" : modelFromConfig ? "config" : "codex-default",
    reasoningEffort: options.reasoningEffort || reasoningFromConfig || "Codex default",
    reasoningEffortSource: options.reasoningEffort ? "flag" : reasoningFromConfig ? "config" : "codex-default",
    serviceTier,
    serviceTierSource,
    fastModeApplied,
    fastModeDetail,
    configPath: config.path,
    sandbox: options.sandbox,
    network,
    networkSource,
    maxCycles: options.maxCycles,
    reviewLimit: options.reviewLimit,
    logStyle: options.logStyle,
  };
}

function stringValue(value) {
  return typeof value === "string" && value.trim() ? value.trim() : "";
}

function booleanValue(value) {
  return typeof value === "boolean" ? value : null;
}

function formatEffectiveNetwork(effective) {
  if (typeof effective.network !== "boolean") {
    return "Codex default (codex-default)";
  }
  return `${effective.network ? "enabled" : "disabled"} (${effective.networkSource})`;
}

function printEffectiveConfig(planFile, options) {
  const effective = effectiveCodexConfig(options);
  console.log(`Model: ${effective.model} (${effective.modelSource})`);
  console.log(`Reasoning effort: ${effective.reasoningEffort} (${effective.reasoningEffortSource})`);
  console.log(`Fast mode: ${effective.fastModeApplied ? "yes" : "no"} (${effective.fastModeDetail}, ${effective.serviceTierSource})`);
  console.log(`Config: ${effective.configPath}`);
  console.log(`Plan file: ${planFile}`);
  console.log(`Sandbox: ${effective.sandbox}`);
  console.log(`Network: ${formatEffectiveNetwork(effective)}`);
  console.log(`Max cycles: ${effective.maxCycles}`);
  console.log(`Review limit: ${effective.reviewLimit}`);
  console.log(`Log style: ${effective.logStyle}`);
}

function progressSchema() {
  return {
    type: "object",
    additionalProperties: false,
    properties: {
      status: {
        type: "string",
        enum: ["progressed", "complete", "blocked", "decision_needed", "failed"],
      },
      summary: { type: "string" },
      commit_title: { type: "string" },
      validation: { type: "string" },
      next_action: { type: "string" },
      completed_coherent_slice: { type: "boolean" },
    },
    required: [
      "status",
      "summary",
      "commit_title",
      "validation",
      "next_action",
      "completed_coherent_slice",
    ],
  };
}

function reviewSchema() {
  return {
    type: "object",
    additionalProperties: false,
    properties: {
      status: {
        type: "string",
        enum: ["clean", "bucket1_applied", "bucket2_only", "blocked", "validation_failed"],
      },
      summary: { type: "string" },
      bucket1_applied_count: { type: "integer", minimum: 0 },
      bucket2_items: {
        type: "array",
        items: {
          type: "object",
          additionalProperties: false,
          properties: {
            priority: { type: "string" },
            title: { type: "string" },
            recommendation: { type: "string" },
            blocks_remaining_plan: { type: "boolean" },
          },
          required: ["priority", "title", "recommendation", "blocks_remaining_plan"],
        },
      },
      validation: { type: "string" },
    },
    required: ["status", "summary", "bucket1_applied_count", "bucket2_items", "validation"],
  };
}

function buildCodexArgs({ options, schemaFile, lastMessageFile, prompt }) {
  const args = [
    "exec",
    "--json",
    "-o",
    lastMessageFile,
    "--output-schema",
    schemaFile,
    "--sandbox",
    options.sandbox,
    "-c",
    'approval_policy="never"',
  ];

  if (typeof options.network === "boolean") {
    args.push("-c", `sandbox_workspace_write.network_access=${options.network ? "true" : "false"}`);
  }

  if (options.model) {
    args.push("--model", options.model);
  }

  if (options.reasoningEffort) {
    args.push("-c", `model_reasoning_effort=${JSON.stringify(options.reasoningEffort)}`);
  }

  if (options.serviceTier) {
    args.push("-c", `service_tier=${JSON.stringify(options.serviceTier)}`);
  }

  args.push(prompt);
  return args;
}

function runCodexPhase({ repoRoot, runDir, phaseName, cycle, pass, options, schema, prompt }) {
  const prefix = `cycle-${cycle}-${phaseName}${pass ? `-${pass}` : ""}`;
  return runSharedCodexPhase({
    repoRoot,
    runDir,
    prefix,
    options,
    schema,
    prompt,
    buildCodexArgs,
    commandName: "codex-plan-loop",
  });
}

function buildProgressPrompt(planPath, planRelPath, cycle) {
  return `Use $progress-run to execute the next clear slice from ${planRelPath}.

Plan file: ${planPath}
Cycle: ${cycle}

Requirements:
- Read the plan file first and treat it as the progress tracker.
- Execute exactly one coherent progress slice.
- Update the same plan file as work proceeds.
- Run relevant validation when practical.
- Do not stage, commit, push, or run a post-review loop.
- Stop if the plan is complete, blocked, or needs a decision.
- Set completed_coherent_slice to true only when the current working-tree changes are safe to review and commit as one slice.
- Set status to complete only when the full plan is done.
- Set status to decision_needed when user input is required.
- Set status to blocked when progress cannot safely continue without external change.
- Set status to failed when validation or execution failed in a way that should stop automation.

Return only JSON matching the provided schema.`;
}

function buildReviewPrompt(planPath, planRelPath, reviewPass) {
  return buildPlanReviewPrompt({ planPath, planRelPath, reviewPass });
}

function gitStatus(repoRoot) {
  return requireSuccessful("git", ["status", "--porcelain=v1"], { cwd: repoRoot });
}

function hasChanges(repoRoot) {
  return gitStatus(repoRoot).trim().length > 0;
}

function pathHasChanges(repoRoot, relativePath) {
  const status = requireSuccessful("git", ["status", "--porcelain=v1", "--", relativePath], { cwd: repoRoot });
  return status.trim().length > 0;
}

function stageAndCommit(repoRoot, title, bodyLines) {
  requireSuccessful("git", ["add", "-A"], { cwd: repoRoot });
  const staged = runSync("git", ["diff", "--cached", "--quiet"], { cwd: repoRoot });
  if (staged.status === 0) {
    throw new Error("nothing staged after git add -A");
  }

  const messageFile = path.join(repoRoot, ".git", "codex-plan-loop-commit-message.txt");
  const message = [sanitizeTitle(title), "", ...bodyLines.filter(Boolean)].join("\n");
  fs.writeFileSync(messageFile, `${message.trim()}\n`);

  try {
    requireSuccessful("git", ["commit", "-F", messageFile], { cwd: repoRoot });
  } finally {
    fs.rmSync(messageFile, { force: true });
  }
}

function sanitizeTitle(title) {
  const cleaned = String(title || "Update plan progress")
    .replace(/\s+/g, " ")
    .trim();
  if (!cleaned) return "Update plan progress";
  return cleaned.length <= 72 ? cleaned : cleaned.slice(0, 69).trimEnd() + "...";
}

function summarizeBucket2(items) {
  if (!items.length) return "No unresolved Bucket II decisions.";
  return items
    .map((item, index) => {
      const blocking = item.blocks_remaining_plan ? "blocking" : "deferred";
      return `${index + 1}. [${blocking}] ${item.priority} ${item.title}: ${item.recommendation}`;
    })
    .join("\n");
}

function uniqueBucket2(existing, incoming) {
  const seen = new Set(existing.map((item) => `${item.priority}\0${item.title}\0${item.recommendation}`));
  const merged = [...existing];
  for (const item of incoming) {
    const key = `${item.priority}\0${item.title}\0${item.recommendation}`;
    if (!seen.has(key)) {
      seen.add(key);
      merged.push(item);
    }
  }
  return merged;
}

async function main() {
  const { planFile, options } = parseArgs(process.argv.slice(2));
  const repoRoot = findRepoRoot();
  const planPath = path.resolve(process.cwd(), planFile);

  if (options.printEffectiveConfig) {
    printEffectiveConfig(planFile, options);
    return 0;
  }

  ensureCommand("codex");
  if (!fs.existsSync(planPath)) {
    throw new Error(`plan file does not exist: ${planPath}`);
  }
  if (!planPath.startsWith(`${repoRoot}${path.sep}`) && planPath !== repoRoot) {
    throw new Error(`plan file must be inside repo root: ${repoRoot}`);
  }
  ensureCleanWorktree(repoRoot);

  const runDir = makeRunDir(repoRoot);
  const planRelPath = path.relative(repoRoot, planPath);
  const effectiveConfig = effectiveCodexConfig(options);
  let bucket2Items = [];

  console.error(`[codex-plan-loop] repo: ${repoRoot}`);
  console.error(`[codex-plan-loop] plan: ${planRelPath}`);
  console.error(`[codex-plan-loop] model: ${effectiveConfig.model} (${effectiveConfig.modelSource})`);
  console.error(`[codex-plan-loop] reasoning effort: ${effectiveConfig.reasoningEffort} (${effectiveConfig.reasoningEffortSource})`);
  console.error(
    `[codex-plan-loop] fast mode: ${effectiveConfig.fastModeApplied ? "yes" : "no"} (${effectiveConfig.fastModeDetail}, ${effectiveConfig.serviceTierSource})`,
  );
  console.error(`[codex-plan-loop] run state: ${runDir}`);
  writeJson(path.join(runDir, "start.json"), {
    repoRoot,
    plan: planRelPath,
    options,
    effectiveConfig,
  });

  for (let cycle = 1; cycle <= options.maxCycles; cycle += 1) {
    const progress = await runCodexPhase({
      repoRoot,
      runDir,
      phaseName: "progress",
      cycle,
      options,
      schema: progressSchema(),
      prompt: buildProgressPrompt(planPath, planRelPath, cycle),
    });

    const dirtyAfterProgress = hasChanges(repoRoot);
    writeJson(path.join(runDir, `cycle-${cycle}-progress-status.json`), {
      progress,
      dirtyAfterProgress,
    });

    if (progress.status === "failed") {
      return finish("failed", runDir, bucket2Items, progress.summary);
    }

    if (!dirtyAfterProgress) {
      if (progress.status === "complete") {
        return finish("complete", runDir, bucket2Items, progress.summary);
      }
      return finish(progress.status, runDir, bucket2Items, progress.summary || "No working-tree changes were produced.");
    }

    if (!progress.completed_coherent_slice) {
      return finish("blocked", runDir, bucket2Items, "Progress produced changes that were not marked as a coherent committable slice.");
    }

    let lastReview = null;
    for (let reviewPass = 1; reviewPass <= options.reviewLimit; reviewPass += 1) {
      lastReview = await runCodexPhase({
        repoRoot,
        runDir,
        phaseName: "review",
        cycle,
        pass: reviewPass,
        options,
        schema: reviewSchema(),
        prompt: buildReviewPrompt(planPath, planRelPath, reviewPass),
      });

      bucket2Items = uniqueBucket2(bucket2Items, lastReview.bucket2_items || []);
      writeJson(path.join(runDir, `cycle-${cycle}-bucket2.json`), bucket2Items);

      if (pathHasChanges(repoRoot, "reviews/codex-review-loop.md")) {
        return finish("blocked", runDir, bucket2Items, "Review attempted to create or modify a persistent review ledger; stopping before commit.");
      }

      const blockingBucket2 = (lastReview.bucket2_items || []).some((item) => item.blocks_remaining_plan);
      if (lastReview.status === "bucket1_applied") {
        continue;
      }
      if (lastReview.status === "blocked" || blockingBucket2) {
        return finish("blocked", runDir, bucket2Items, lastReview.summary);
      }
      if (lastReview.status === "validation_failed") {
        return finish("validation_failed", runDir, bucket2Items, lastReview.summary);
      }
      break;
    }

    if (!lastReview) {
      return finish("failed", runDir, bucket2Items, "Review did not run.");
    }
    if (lastReview.status === "bucket1_applied") {
      return finish("review_limit_reached", runDir, bucket2Items, "Review kept applying Bucket I fixes until the review limit was reached.");
    }

    stageAndCommit(repoRoot, progress.commit_title, [
      `Progress: ${progress.summary}`,
      `Review: ${lastReview.summary}`,
      `Progress validation: ${progress.validation || "not reported"}`,
      `Review validation: ${lastReview.validation || "not reported"}`,
      `Plan: ${planRelPath}`,
    ]);

    console.error(`[codex-plan-loop] committed cycle ${cycle}: ${sanitizeTitle(progress.commit_title)}`);

    if (progress.status === "complete") {
      return finish("complete", runDir, bucket2Items, progress.summary);
    }
    if (progress.status === "blocked" || progress.status === "decision_needed") {
      return finish(progress.status, runDir, bucket2Items, progress.summary);
    }
  }

  return finish("max_cycles_reached", runDir, bucket2Items, `Reached max cycle limit (${options.maxCycles}).`);
}

function finish(status, runDir, bucket2Items, summary) {
  const result = {
    status,
    summary,
    runDir,
    bucket2Items,
  };
  writeJson(path.join(runDir, "final-summary.json"), result);

  console.log(`Status: ${status}`);
  if (summary) console.log(`Summary: ${summary}`);
  console.log(`Run state: ${runDir}`);
  console.log("");
  console.log("Bucket II:");
  console.log(summarizeBucket2(bucket2Items));

  if (["complete", "max_cycles_reached"].includes(status)) {
    return 0;
  }
  return 1;
}

main()
  .then((exitCode) => {
    process.exitCode = exitCode;
  })
  .catch((error) => {
    console.error(`[codex-plan-loop] error: ${error.message}`);
    process.exitCode = 1;
  });

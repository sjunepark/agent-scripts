{
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$PLUGIN_ROOT/scripts/pushover-notify.mjs\"",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$PLUGIN_ROOT/scripts/pushover-notify.mjs\"",
            "timeout": 15,
            "statusMessage": "Sending Pushover notification"
          }
        ]
      }
    ]
  }
}

{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$PLUGIN_ROOT/scripts/session-id-context.py\"",
            "commandWindows": "py -3 \"%PLUGIN_ROOT%\\scripts\\session-id-context.py\"",
            "timeout": 5
          }
        ]
      }
    ]
  }
}

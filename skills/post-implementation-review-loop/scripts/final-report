#!/usr/bin/env python3
"""Render the deterministic final report for post-implementation-review-loop.

The agent owns collecting and verifying facts in the cumulative ledger. This
script owns the final Markdown shape so loop termination is deterministic.
"""

from __future__ import annotations

import argparse
import json
import re
import sys
from typing import Any, Dict, Iterable, List, Optional


REPORT_FORMAT = "post-implementation-review-loop-final-report-v1"
VERDICTS = {
    "Loop clean: no accepted/actionable Bucket I findings remain",
    "Loop stopped: Bucket II decision needed",
    "Loop stopped: iteration limit reached",
    "Loop stopped: validation failure remains",
    "Loop stopped: scope or context needed",
    "Loop stopped: phase_checkpoint_compact unavailable",
}
VALIDATION_RESULTS = {"passed", "failed", "skipped"}
BUCKET_I_STATUSES = {"accepted", "applied", "rejected", "remaining"}
BUCKET_II_STATUSES = {
    "left for user decision",
    "deferred",
    "kept as-is for now",
    "implemented after explicit approval",
}


def usage_error(message: str) -> None:
    print(json.dumps({"error": message}, indent=2), file=sys.stderr)
    raise SystemExit(2)


def read_payload(path: Optional[str]) -> Dict[str, Any]:
    try:
        raw = sys.stdin.read() if path in (None, "-") else open(path, encoding="utf-8").read()
    except OSError as exc:
        usage_error(f"failed to read input: {exc}")

    if not raw.strip():
        usage_error("input JSON is required")

    try:
        payload = json.loads(raw)
    except json.JSONDecodeError as exc:
        usage_error(f"invalid JSON: {exc}")

    if not isinstance(payload, dict):
        usage_error("input JSON must be an object")
    return payload


def require_key(payload: Dict[str, Any], key: str) -> Any:
    if key not in payload:
        usage_error(f"{key} is required")
    return payload[key]


def require_dict(payload: Dict[str, Any], key: str) -> Dict[str, Any]:
    value = require_key(payload, key)
    if not isinstance(value, dict):
        usage_error(f"{key} must be an object")
    return value


def require_list(payload: Dict[str, Any], key: str) -> List[Any]:
    value = require_key(payload, key)
    if not isinstance(value, list):
        usage_error(f"{key} must be a list")
    return value


def report_text(value: str) -> str:
    """Return renderer-safe single-line text for deterministic Markdown shape."""
    return re.sub(r"\s+", " ", value.strip())


def require_str(payload: Dict[str, Any], key: str) -> str:
    value = require_key(payload, key)
    if not isinstance(value, str) or not value.strip():
        usage_error(f"{key} must be a non-empty string")
    return report_text(value)


def require_bool(payload: Dict[str, Any], key: str) -> bool:
    value = require_key(payload, key)
    if not isinstance(value, bool):
        usage_error(f"{key} must be a boolean")
    return value


def require_int(payload: Dict[str, Any], key: str) -> int:
    value = require_key(payload, key)
    if isinstance(value, bool) or not isinstance(value, int):
        usage_error(f"{key} must be an integer")
    if value < 0:
        usage_error(f"{key} must be non-negative")
    return value


def string_list(values: Iterable[Any], field: str) -> List[str]:
    result: List[str] = []
    for index, value in enumerate(values, start=1):
        if not isinstance(value, str) or not value.strip():
            usage_error(f"{field}[{index}] must be a non-empty string")
        result.append(report_text(value))
    return result


def markdown_escape_table(value: str) -> str:
    return value.replace("|", "\\|").replace("\n", "<br>")


def numbered_section(items: List[str], empty: str) -> str:
    if not items:
        return empty
    return "\n\n".join(items)


def format_validation_refs(value: Any, field: str) -> str:
    if isinstance(value, str) and value.strip():
        return report_text(value)
    if isinstance(value, list):
        refs = string_list(value, field)
        if refs:
            return "; ".join(refs)
        usage_error(f"{field} must include at least one validation reference or be a non-empty string")
    usage_error(f"{field} must be a string or list of strings")


def validate_baseline(payload: Dict[str, Any]) -> Dict[str, Any]:
    baseline = require_dict(payload, "baseline")
    return {
        "ref": require_str(baseline, "ref"),
        "createdCommit": require_bool(baseline, "createdCommit"),
        "scopedFiles": string_list(require_list(baseline, "scopedFiles"), "baseline.scopedFiles"),
    }


def validate_iterations(payload: Dict[str, Any]) -> Dict[str, Any]:
    iterations = require_dict(payload, "iterations")
    completed = require_int(iterations, "completed")
    limit = require_int(iterations, "limit")
    if limit < 1:
        usage_error("iterations.limit must be at least 1")
    if completed < 0:
        usage_error("iterations.completed must be non-negative")
    return iterations


def validate_validation(payload: Dict[str, Any]) -> List[Dict[str, str]]:
    records = require_list(payload, "validation")
    result: List[Dict[str, str]] = []
    for index, raw in enumerate(records, start=1):
        if not isinstance(raw, dict):
            usage_error(f"validation[{index}] must be an object")
        command = require_str(raw, "command")
        status = require_str(raw, "result")
        if status not in VALIDATION_RESULTS:
            usage_error(f"validation[{index}].result must be one of: {', '.join(sorted(VALIDATION_RESULTS))}")
        result.append(
            {
                "command": command,
                "result": status,
                "phase": require_str(raw, "phase"),
                "notes": require_str(raw, "notes"),
            }
        )
    return result


def validate_bucket_i(payload: Dict[str, Any]) -> List[Dict[str, Any]]:
    records = require_list(payload, "bucketI")
    result: List[Dict[str, Any]] = []
    for index, raw in enumerate(records, start=1):
        if not isinstance(raw, dict):
            usage_error(f"bucketI[{index}] must be an object")
        status = require_str(raw, "status")
        if status not in BUCKET_I_STATUSES:
            usage_error(f"bucketI[{index}].status must be one of: {', '.join(sorted(BUCKET_I_STATUSES))}")
        result.append(
            {
                "title": require_str(raw, "title"),
                "revealed": require_str(raw, "revealed"),
                "status": status,
                "fix": require_str(raw, "fix"),
                "files": string_list(require_list(raw, "files"), f"bucketI[{index}].files"),
                "bandageReason": require_str(raw, "bandageReason"),
                "validation": format_validation_refs(require_key(raw, "validation"), f"bucketI[{index}].validation"),
            }
        )
    return result


def validate_bucket_ii(payload: Dict[str, Any]) -> List[Dict[str, Any]]:
    records = require_list(payload, "bucketII")
    result: List[Dict[str, Any]] = []
    for index, raw in enumerate(records, start=1):
        if not isinstance(raw, dict):
            usage_error(f"bucketII[{index}] must be an object")
        status = require_str(raw, "status")
        if status not in BUCKET_II_STATUSES:
            usage_error(f"bucketII[{index}].status must be one of: {', '.join(sorted(BUCKET_II_STATUSES))}")
        result.append(
            {
                "title": require_str(raw, "title"),
                "revealed": require_str(raw, "revealed"),
                "weakness": require_str(raw, "weakness"),
                "options": string_list(require_list(raw, "options"), f"bucketII[{index}].options"),
                "recommendedAction": require_str(raw, "recommendedAction"),
                "tradeoffs": require_str(raw, "tradeoffs"),
                "status": status,
            }
        )
    return result


def validate_code_changes(payload: Dict[str, Any]) -> List[Dict[str, Any]]:
    records = require_list(payload, "codeChanges")
    result: List[Dict[str, Any]] = []
    for index, raw in enumerate(records, start=1):
        if not isinstance(raw, dict):
            usage_error(f"codeChanges[{index}] must be an object")
        result.append(
            {
                "title": require_str(raw, "title"),
                "files": string_list(require_list(raw, "files"), f"codeChanges[{index}].files"),
                "issueAddressed": require_str(raw, "issueAddressed"),
                "scopeReason": require_str(raw, "scopeReason"),
                "validation": format_validation_refs(require_key(raw, "validation"), f"codeChanges[{index}].validation"),
                "inspect": require_str(raw, "inspect"),
            }
        )
    return result


def validate_rejected(payload: Dict[str, Any]) -> List[Dict[str, str]]:
    records = require_list(payload, "rejectedOrKeptAsIs")
    result: List[Dict[str, str]] = []
    for index, raw in enumerate(records, start=1):
        if not isinstance(raw, dict):
            usage_error(f"rejectedOrKeptAsIs[{index}] must be an object")
        result.append({"title": require_str(raw, "title"), "reason": require_str(raw, "reason")})
    return result


def validate_phase_history(payload: Dict[str, Any]) -> List[Dict[str, Any]]:
    records = require_list(payload, "phasesRun")
    result: List[Dict[str, Any]] = []
    for index, raw in enumerate(records, start=1):
        if not isinstance(raw, dict):
            usage_error(f"phasesRun[{index}] must be an object")
        result.append(
            {
                "phase": require_str(raw, "phase"),
                "iteration": require_int(raw, "iteration"),
                "gateDecision": require_str(raw, "gateDecision"),
                "summary": require_str(raw, "summary"),
            }
        )
    return result


def validate_final_gate(payload: Dict[str, Any]) -> Dict[str, Any]:
    gate = require_dict(payload, "finalGate")
    decision = require_str(gate, "decision")
    if decision != "stop":
        usage_error("finalGate.decision must be stop")
    next_phase = require_str(gate, "nextPhase")
    if next_phase != "final report":
        usage_error("finalGate.nextPhase must be final report")
    if gate.get("checkpointRequired") is not False:
        usage_error("finalGate.checkpointRequired must be false")
    required_action = require_str(gate, "requiredAction")
    if required_action != "render_final_report":
        usage_error("finalGate.requiredAction must be render_final_report")
    if gate.get("reportRequired") is not True:
        usage_error("finalGate.reportRequired must be true")
    report_format = require_str(gate, "reportFormat")
    if report_format != REPORT_FORMAT:
        usage_error(f"finalGate.reportFormat must be {REPORT_FORMAT}")
    return {
        "decision": decision,
        "nextPhase": next_phase,
        "checkpointRequired": False,
        "requiredAction": required_action,
        "reportRequired": True,
        "reportFormat": report_format,
        "reason": require_str(gate, "reason"),
    }


def validate_payload(payload: Dict[str, Any]) -> Dict[str, Any]:
    report_format = require_str(payload, "reportFormat")
    if report_format != REPORT_FORMAT:
        usage_error(f"reportFormat must be {REPORT_FORMAT}")

    verdict = require_str(payload, "verdict")
    if verdict not in VERDICTS:
        usage_error(f"verdict must be one of: {', '.join(sorted(VERDICTS))}")

    return {
        "baseline": validate_baseline(payload),
        "scope": require_str(payload, "scope"),
        "iterations": validate_iterations(payload),
        "phasesRun": validate_phase_history(payload),
        "filesChanged": string_list(require_list(payload, "filesChanged"), "filesChanged"),
        "validation": validate_validation(payload),
        "finalCleanCondition": require_str(payload, "finalCleanCondition"),
        "finalDiffInspection": require_str(payload, "finalDiffInspection"),
        "bucketI": validate_bucket_i(payload),
        "bucketII": validate_bucket_ii(payload),
        "codeChanges": validate_code_changes(payload),
        "rejectedOrKeptAsIs": validate_rejected(payload),
        "finalGate": validate_final_gate(payload),
        "verdict": verdict,
    }


def render_validation_table(records: List[Dict[str, str]]) -> str:
    if not records:
        return "No validation commands were recorded."
    lines = ["| Command | Result | Phase | Notes |", "| --- | --- | --- | --- |"]
    for record in records:
        lines.append(
            "| "
            + " | ".join(
                markdown_escape_table(record[field])
                for field in ("command", "result", "phase", "notes")
            )
            + " |"
        )
    return "\n".join(lines)


def render_bucket_i(records: List[Dict[str, Any]]) -> str:
    sections: List[str] = []
    for index, item in enumerate(records, start=1):
        files = ", ".join(item["files"]) if item["files"] else "None recorded"
        sections.append(
            f"{index}. {item['title']}\n"
            f"   - Revealed: {item['revealed']}\n"
            f"   - Status: {item['status']}\n"
            f"   - Root-cause fix/refactor: {item['fix']}\n"
            f"   - Files changed: {files}\n"
            f"   - Bandage avoided: {item['bandageReason']}\n"
            f"   - Validation evidence: {item['validation']}"
        )
    return numbered_section(sections, "No Bucket I findings were found.")


def render_bucket_ii(records: List[Dict[str, Any]]) -> str:
    sections: List[str] = []
    for index, item in enumerate(records, start=1):
        options = "; ".join(item["options"]) if item["options"] else "None recorded"
        sections.append(
            f"{index}. {item['title']}\n"
            f"   - Revealed: {item['revealed']}\n"
            f"   - Design or quality weakness: {item['weakness']}\n"
            f"   - Options / decision points: {options}\n"
            f"   - Recommended action: {item['recommendedAction']}\n"
            f"   - Tradeoffs / uncertainty: {item['tradeoffs']}\n"
            f"   - Status: {item['status']}"
        )
    return numbered_section(sections, "No Bucket II findings were found.")


def render_code_changes(records: List[Dict[str, Any]]) -> str:
    sections: List[str] = []
    for index, item in enumerate(records, start=1):
        sections.append(
            f"{index}. {item['title']}\n"
            f"   - Files: {', '.join(item['files'])}\n"
            f"   - Issue addressed: {item['issueAddressed']}\n"
            f"   - Why this scope: {item['scopeReason']}\n"
            f"   - Validation evidence: {item['validation']}\n"
            f"   - Inspect with: `{item['inspect']}`"
        )
    return numbered_section(sections, "No code changes were applied by the loop.")


def render_rejected(records: List[Dict[str, str]]) -> str:
    if not records:
        return "None."
    return "\n".join(f"- {item['title']}: {item['reason']}" for item in records)


def render_phases(records: List[Dict[str, Any]]) -> str:
    if not records:
        return "None recorded."
    return "\n".join(
        f"- Iteration {item['iteration']} `{item['phase']}` — {item['gateDecision']}; {item['summary']}"
        for item in records
    )


def render_report(data: Dict[str, Any]) -> str:
    baseline = data["baseline"]
    iterations = data["iterations"]
    baseline_kind = "WIP baseline commit created" if baseline["createdCommit"] else "Existing HEAD recorded"
    scoped_files_text = ", ".join(baseline["scopedFiles"]) if baseline["scopedFiles"] else "None recorded"
    files_changed = data["filesChanged"]
    files_changed_text = ", ".join(files_changed) if files_changed else "None"
    final_gate = data["finalGate"]

    return "\n".join(
        [
            "# Post-Implementation Review Loop Report",
            "",
            "## Summary",
            "",
            f"- Baseline: `{baseline['ref']}` ({baseline_kind})",
            f"- Baseline scoped files: {scoped_files_text}",
            f"- Scope: {data['scope']}",
            f"- Iterations: {iterations['completed']}/{iterations['limit']}",
            f"- Files changed by loop: {files_changed_text}",
            f"- Stop reason: {final_gate['reason']}",
            f"- Final clean condition: {data['finalCleanCondition']}",
            f"- Final diff / validation confirmation: {data['finalDiffInspection']}",
            f"- Verdict: {data['verdict']}",
            "",
            "## Phases Run",
            "",
            render_phases(data["phasesRun"]),
            "",
            "## Validation",
            "",
            render_validation_table(data["validation"]),
            "",
            "## Bucket I — Findings and Fixes",
            "",
            render_bucket_i(data["bucketI"]),
            "",
            "## Bucket II — Findings and Recommendations",
            "",
            render_bucket_ii(data["bucketII"]),
            "",
            "## Code Changes Applied",
            "",
            render_code_changes(data["codeChanges"]),
            "",
            "## Rejected / Kept As-Is",
            "",
            render_rejected(data["rejectedOrKeptAsIs"]),
            "",
            "## Final Verdict",
            "",
            data["verdict"],
            "",
        ]
    )


def main() -> None:
    parser = argparse.ArgumentParser(
        description="Render the deterministic final report for post-implementation-review-loop."
    )
    parser.add_argument("--input", "-i", help="JSON ledger file to read; defaults to stdin")
    args = parser.parse_args()

    print(render_report(validate_payload(read_payload(args.input))), end="")


if __name__ == "__main__":
    main()

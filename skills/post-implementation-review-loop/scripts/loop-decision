#!/usr/bin/env python3
"""Deterministic phase gate for the post-implementation-review-loop skill.

Read a JSON phase snapshot from stdin or --input and print the single allowed
transition as JSON. The script does not review or fix code; it only makes stop
vs continue decisions deterministic.
"""

from __future__ import annotations

import argparse
import json
import sys
from typing import Any, Dict, Optional


PHASES = {"post-review", "impl-review", "impl"}


def usage_error(message: str) -> None:
    print(json.dumps({"decision": "invalid", "error": message}, indent=2), file=sys.stderr)
    raise SystemExit(2)


def read_payload(path: Optional[str]) -> Dict[str, Any]:
    try:
        raw = sys.stdin.read() if path in (None, "-") else open(path, encoding="utf-8").read()
    except OSError as exc:
        usage_error(f"failed to read input: {exc}")

    if not raw.strip():
        usage_error("input JSON is required")

    try:
        payload = json.loads(raw)
    except json.JSONDecodeError as exc:
        usage_error(f"invalid JSON: {exc}")

    if not isinstance(payload, dict):
        usage_error("input JSON must be an object")
    return payload


def as_bool(payload: Dict[str, Any], key: str) -> bool:
    value = payload.get(key, False)
    if isinstance(value, bool):
        return value
    usage_error(f"{key} must be a boolean")


def as_int(payload: Dict[str, Any], key: str, default: Optional[int] = None) -> int:
    value = payload.get(key, default)
    if value is None:
        usage_error(f"{key} is required")
    if isinstance(value, bool) or not isinstance(value, int):
        usage_error(f"{key} must be an integer")
    if value < 0:
        usage_error(f"{key} must be non-negative")
    return value


def count_value(payload: Dict[str, Any], key: str, required: bool = False) -> int:
    if key not in payload:
        if required:
            usage_error(f"{key} is required")
        return 0
    value = payload[key]
    if isinstance(value, bool):
        usage_error(f"{key} must be an integer count or list, not a boolean")
    if isinstance(value, int):
        if value < 0:
            usage_error(f"{key} must be non-negative")
        return value
    if isinstance(value, list):
        return len(value)
    usage_error(f"{key} must be an integer count or list")


def stop(next_phase: str, reason: str) -> Dict[str, Any]:
    return {
        "decision": "stop",
        "nextPhase": next_phase,
        "checkpointRequired": False,
        "reason": reason,
    }


def cont(next_phase: str, reason: str, checkpoint_required: bool = False) -> Dict[str, Any]:
    return {
        "decision": "continue",
        "nextPhase": next_phase,
        "checkpointRequired": checkpoint_required,
        "reason": reason,
    }


def decide(payload: Dict[str, Any]) -> Dict[str, Any]:
    phase = payload.get("phase")
    if phase not in PHASES:
        usage_error(f"phase must be one of: {', '.join(sorted(PHASES))}")

    iteration = as_int(payload, "iteration")
    limit = as_int(payload, "limit")
    if limit < 1:
        usage_error("limit must be at least 1")
    if iteration < 1:
        usage_error("iteration must be at least 1")

    review_only = as_bool(payload, "reviewOnly")
    scope_blocked = as_bool(payload, "scopeBlocked")
    validation_blocked = as_bool(payload, "validationBlocked")
    checkpoint_unavailable = as_bool(payload, "checkpointUnavailable")

    if checkpoint_unavailable:
        return stop("final briefing", "phase_checkpoint_compact is unavailable")
    if review_only:
        return stop("final briefing", "user requested a review-only pass")
    if scope_blocked:
        return stop("final briefing", "scope or context is missing")
    if validation_blocked:
        return stop("final briefing", "validation is blocking safe continuation")

    if phase == "post-review":
        bucket_i_candidates = count_value(payload, "bucketICandidates", required=True)
        bucket_ii = count_value(payload, "bucketII", required=True)
        if bucket_i_candidates == 0:
            if bucket_ii > 0:
                return stop("final briefing", "only Bucket II work remains")
            return stop("final briefing", "no Bucket I candidates found")
        if iteration >= limit:
            return stop("final briefing", "iteration limit reached after post-review")
        return cont("impl-review", "Bucket I candidates exist and no stop condition is active")

    if phase == "impl-review":
        accepted_bucket_i = count_value(payload, "acceptedBucketI", required=True)
        bucket_ii = count_value(payload, "bucketII", required=True)
        if accepted_bucket_i == 0:
            if bucket_ii > 0:
                return stop("final briefing", "only Bucket II work remains")
            return stop("final briefing", "no accepted/actionable Bucket I items remain")
        if iteration >= limit:
            return stop("final briefing", "iteration limit reached before implementation")
        return cont("impl", "accepted/actionable Bucket I work exists and no stop condition is active")

    # impl
    applied_bucket_i = count_value(payload, "appliedBucketI", required=True)
    if applied_bucket_i == 0:
        return stop("final briefing", "implementation phase applied no Bucket I fixes")
    return cont("post-review", "implementation completed; checkpoint before the next review", checkpoint_required=True)


def main() -> None:
    parser = argparse.ArgumentParser(
        description="Choose the deterministic next phase for post-implementation-review-loop."
    )
    parser.add_argument("--input", "-i", help="JSON file to read; defaults to stdin")
    parser.add_argument("--pretty", action="store_true", help="Pretty-print JSON output")
    args = parser.parse_args()

    result = decide(read_payload(args.input))
    print(json.dumps(result, indent=2 if args.pretty else None, sort_keys=args.pretty))


if __name__ == "__main__":
    main()
